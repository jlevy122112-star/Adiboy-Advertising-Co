# Copy to `.env` in this directory (or export in your shell) for local API + migrations.
# Postgres (see `docker-compose.yml` in this repo):
DATABASE_URL=postgres://postgres:dev@127.0.0.1:5432/marketer
# BullMQ + `publish-roundtrip` Vitest (default matches docker-compose `redis` service):
# REDIS_URL=redis://127.0.0.1:6379
# Optional — OpenAI for generation draft bodies (Phase 2). Prefer MARKETER_OPENAI_API_KEY on shared machines.
# MARKETER_OPENAI_API_KEY=
# OPENAI_API_KEY=
# MARKETER_OPENAI_BASE_URL=https://api.openai.com/v1
# MARKETER_GENERATION_MODEL=gpt-4o-mini
