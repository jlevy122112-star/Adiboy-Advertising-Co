# Copy to `.env` in this directory (or export in your shell) for local dev.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:dev@127.0.0.1:5432/marketer

# ── Redis / BullMQ ────────────────────────────────────────────────────────────
# REDIS_URL=redis://127.0.0.1:6379

# ── MVP Server ────────────────────────────────────────────────────────────────
MARKETER_JWT_SECRET=change-me-to-a-random-32-char-string
MVP_PORT=8780
# MVP_CORS=http://localhost:5173

# ── AI Generation (use either Anthropic or OpenAI) ───────────────────────────
# Anthropic (preferred)
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI (fallback)
MARKETER_OPENAI_API_KEY=sk-...
# MARKETER_OPENAI_BASE_URL=https://api.openai.com/v1
# MARKETER_GENERATION_MODEL=gpt-4o-mini

# ── SERP research ─────────────────────────────────────────────────────────────
SERPAPI_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── AWS S3 (video generation / image uploads) ─────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
# AWS_S3_REGION=us-east-1

# ── Social OAuth credentials ──────────────────────────────────────────────────
# X (Twitter)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Meta / Facebook + Instagram
META_APP_ID=
META_APP_SECRET=
# Dev-only static tokens (bypass full OAuth for testing):
MARKETER_META_ACCESS_TOKEN=
MARKETER_INSTAGRAM_ACCESS_TOKEN=
MARKETER_INSTAGRAM_USER_ID=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
MARKETER_LINKEDIN_ACCESS_TOKEN=

# YouTube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
MARKETER_YOUTUBE_ACCESS_TOKEN=
MARKETER_YOUTUBE_CHANNEL_ID=

# TikTok (requires partner program approval)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Pinterest (coming soon)
# PINTEREST_APP_ID=
# PINTEREST_APP_SECRET=

