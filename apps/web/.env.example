VITE_CAMPAIGN_API_ORIGIN=http://127.0.0.1:8801
VITE_SERP_API_ORIGIN=http://127.0.0.1:8802
VITE_AUTONOMOUS_API_ORIGIN=http://127.0.0.1:8805
VITE_SENTIMENT_API_ORIGIN=http://127.0.0.1:8803
VITE_PREDICTIVE_API_ORIGIN=http://127.0.0.1:8804
