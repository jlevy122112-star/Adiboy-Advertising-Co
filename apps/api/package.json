{
  "name": "@home-link/marketer-api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prebuild": "npm run build -w @home-link/marketer-pro-contract --prefix ../..",
    "build": "tsc -p tsconfig.json --pretty false",
    "typecheck": "tsc -p tsconfig.json --pretty false",
    "start:internal": "node dist/internal-publish-server.js",
    "start:generation-draft": "node dist/generation-draft-server.js",
    "start:campaign": "node dist/campaign-server.js",
    "start:brand-profile": "node dist/brand-profile-server.js",
    "start:brand-memory": "node dist/brand-memory-server.js",
    "start:scheduler": "node dist/scheduler-publish-server.js",
    "start:image-gen": "node dist/image-gen-server.js",
    "start:video-gen": "node dist/video-gen-server.js",
    "start:video-worker": "node dist/video-worker-cli.js",
    "start:auth": "node dist/auth-server.js",
    "start:social-oauth": "node dist/social-oauth-server.js",
    "db:migrate": "node scripts/migrate.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/lib-storage": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@home-link/marketer-pro-contract": "*",
    "@home-link/marketer-pro-queue": "*",
    "@node-rs/argon2": "^2.0.2",
    "bullmq": "^5.76.6",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "postgres": "^3.4.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^22.10.0",
    "typescript": "^5.8.3"
  }
}
